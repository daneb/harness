#!/usr/bin/env bash
# harness — thin orchestrator for the gated agent pipeline.
# SPEC ─G0─▶ PLAN ─G1─▶ IMPLEMENT ─G2─▶ REVIEW ─G2.5─▶ HUMAN ─G3─▶ MERGE ─▶ WRITEBACK
set -euo pipefail
HARNESS_HOME="$(cd "$(dirname "$0")/.." && pwd)"
source "$HARNESS_HOME/lib/common.sh"

usage() {
  cat <<'EOF'
harness — gated agent pipeline (gates, not virtue)

  harness init [dir]          set up .tasks/, decisions/, AGENTS.md, .harness.toml
  harness spec <task>         scaffold .tasks/<task>/SPEC.md (then: write it, approve it)
  harness critique <task>     fresh-context agent attacks your draft spec (advisory, pre-G0)
  harness split <task>        stage a bundled spec as N draft specs (clerical; you approve each)
  harness plan <task>         G0, then planner agent writes PLAN.md, then G1
  harness implement <task>    implementer agent edits the tree, then G2
  harness review <task>       fresh-context reviewer writes review.md, then G2.5
  harness approve <task>      G3 — you read the diff (interactive, never automated)
  harness merge <task>        commit + decision record (requires G3 approval)
  harness gate <g> <task>     run one gate manually (g0|g1|g2|g2.5|g3)
  harness status <task>       show gate progress
  harness diff <task>         show the task's changes from its own tree (no branch checkout)
  harness calibrate           reviewer verdicts vs your G3 decisions (TPR/TNR)
  harness stats               cost, duration, gate failure rates across tasks
  harness doctor              preflight: git, toolchain, adapter, dependencies
  harness version             version + commit
  harness loc                 current repo's product/test/doc line counts

Adapter: $HARNESS_ADAPTER (default "claude") selects adapters/<name>.sh
EOF
  exit "${1:-0}"
}

cmd="${1:-help}"; [ $# -gt 0 ] && shift
adapter="$HARNESS_HOME/adapters/${HARNESS_ADAPTER:-claude}.sh"
GATES="g0 g1 g2 g2.5 g3"

need_task() {
  name="${1:-}"
  [ -n "$name" ] || die "usage: harness $cmd <task-name>"
  root="$(repo_root .)"
  td="$root/.tasks/$name"
  # A command that operates on an existing task, given a name with no task
  # directory, is a typo — say so and list the real tasks (don't let it fail
  # later as a confusing "gate g0 has not passed").
  case "$cmd" in
    critique|split|plan|implement|review|approve|merge|gate|status|diff)
      if [ ! -d "$td" ]; then
        avail=$(cd "$root/.tasks" 2>/dev/null && for d in */; do [ -d "$d" ] && printf '%s ' "${d%/}"; done)
        die "no such task: '$name'${avail:+ — tasks: $avail}"
      fi
      ;;
  esac
  # Merged tasks are history, not targets — gating one judges today's tree
  # against a closed plan and produces nonsense violations.
  case "$cmd" in
    gate|implement|review|approve|merge|plan)
      merged=$(git -C "$root" log --oneline -1 --grep "task($name): merge via harness" 2>/dev/null || true)
      if [ -n "$merged" ]; then
        info "WARNING: task '$name' was already merged ($merged) — did you mean another task?"
      fi
      # Split-brain: a worktree exists but the main checkout has uncommitted
      # non-metadata work the pipeline (which reviews the worktree) won't see.
      if [ -d "$(wt_path)" ]; then
        stray=$(git -C "$root" status --porcelain -uno \
                | sed 's/^...//' | grep -vE '^(\.tasks/|decisions/)' | head -1 || true)
        if [ -n "$stray" ]; then
          info "WARNING: task '$name' has a worktree, but your main checkout has uncommitted changes ($stray, …) the pipeline cannot see — it operates on $(wt_path). Reconcile: work in the worktree, or 'git worktree remove' it to drive from main."
        fi
      fi
      ;;
  esac
}

# Worktree per task (build step 3): agents edit a disposable checkout on a
# task/<name> branch; the user's checkout is untouched until merge.
wt_path() { echo "$(dirname "$root")/$(basename "$root")-worktrees/$name"; }
task_wd() { local w; w="$(wt_path)"; if [ -d "$w" ]; then echo "$w"; else echo "$root"; fi; }

# ensure_wt <path> <branch> [base] — create (or reuse) a worktree
ensure_wt() {
  [ -d "$1" ] && return 0
  mkdir -p "$(dirname "$1")"
  if git -C "$root" show-ref --quiet "refs/heads/$2"; then
    git -C "$root" worktree add "$1" "$2" >/dev/null 2>&1
  else
    git -C "$root" worktree add -b "$2" "$1" "${3:-HEAD}" >/dev/null 2>&1
  fi
}

# bootstrap_wt <wt> — a fresh worktree has tracked files only; install the
# repo's own declared dependencies (the lockfile names the tool). No lockfile
# or no tool → skip silently; the repo declared nothing to install.
bootstrap_wt() {
  local w="$1" blog
  blog="$td/report/bootstrap-$(basename "$w").log"
  [ -d "$w/node_modules" ] && return 0
  if [ -f "$w/package-lock.json" ] && command -v npm >/dev/null 2>&1; then
    info "worktree bootstrap: npm ci (fresh checkout has no node_modules)"
    (cd "$w" && npm ci) > "$blog" 2>&1 || die "worktree bootstrap failed — see $blog"
  elif [ -f "$w/pnpm-lock.yaml" ] && command -v pnpm >/dev/null 2>&1; then
    info "worktree bootstrap: pnpm install --frozen-lockfile"
    (cd "$w" && pnpm install --frozen-lockfile) > "$blog" 2>&1 || die "worktree bootstrap failed — see $blog"
  elif [ -f "$w/yarn.lock" ] && command -v yarn >/dev/null 2>&1; then
    info "worktree bootstrap: yarn install --frozen-lockfile"
    (cd "$w" && yarn install --frozen-lockfile) > "$blog" 2>&1 || die "worktree bootstrap failed — see $blog"
  fi
}

# fan_out <feature-worktree> — parallel implementers for a multi-task plan;
# join, combine into the feature worktree as uncommitted changes.
fan_out() {
  local wt="$1" cap base subs s swt i running failed=""
  cap=$(cfg "$root" fanout_cap 2)
  base=$(git -C "$wt" rev-parse HEAD)
  subs=$(plan_tasks "$td/PLAN.md")
  info "fan-out: $(echo "$subs" | wc -l | tr -d ' ') tasks, cap $cap (G1 verified disjoint scopes)"
  running=0
  reap() {
    i=0
    while [ "$i" -lt "$running" ]; do
      local p ss
      eval "p=\$pid_$i"; eval "ss=\$sub_$i"
      wait "$p" || failed="$failed $ss"
      i=$((i + 1))
    done
    running=0
  }
  for s in $subs; do
    swt="$(dirname "$root")/$(basename "$root")-worktrees/$name--$s"
    ensure_wt "$swt" "task/$name--$s" "$base"
    bootstrap_wt "$swt"
    info "  ↳ $s → $swt"
    HARNESS_SUBTASK="$s" "$adapter" implementer "$td" "$swt" \
      > "$td/report/implement-$s.out" 2>&1 &
    eval "pid_$running=$!"; eval "sub_$running=$s"
    running=$((running + 1))
    [ "$running" -ge "$cap" ] && reap
  done
  reap
  [ -z "$failed" ] || die "fan-out: subtask(s) failed:$failed — see .tasks/$name/report/implement-<task>.out (worktrees kept)"
  # Combine: commit each subtask branch, merge into the feature, then reset
  # so the whole set is uncommitted — the rest of the pipeline is unchanged.
  for s in $subs; do
    swt="$(dirname "$root")/$(basename "$root")-worktrees/$name--$s"
    git -C "$swt" add -A
    git -C "$swt" commit -q -m "wip($name--$s)" --allow-empty
    git -C "$wt" merge -q "task/$name--$s" -m "join $s" \
      || die "fan-out: merge conflict joining '$s' — scopes overlapped in practice; worktree kept at $swt"
    git -C "$root" worktree remove "$swt" >/dev/null 2>&1 || true
    git -C "$root" branch -q -D "task/$name--$s" >/dev/null 2>&1 || true
  done
  git -C "$wt" reset -q --mixed "$base"
  info "fan-out joined: combined changes uncommitted in $wt"
}

require_adapter() {
  [ -x "$adapter" ] || die "no such adapter: ${HARNESS_ADAPTER:-claude} — available: $(cd "$HARNESS_HOME/adapters" && for f in *.sh; do printf '%s ' "${f%.sh}"; done)"
}

require_pass() {
  [ -f "$td/report/$1.pass" ] \
    || die "gate $1 has not passed for '$name' — the pipeline advances only through gates"
}

# Re-running a phase invalidates that gate and everything after it.
invalidate_from() {
  local hit=0 g
  for g in $GATES; do
    [ "$g" = "$1" ] && hit=1
    [ "$hit" -eq 1 ] && rm -f "$td/report/$g.pass"
  done
}

run_gate() {
  local g="$1" script
  local gwd="$root"
  case "$g" in
    g0)   script="g0-spec.sh"   ;;
    g1)   script="g1-plan.sh"   ; gwd="$(task_wd)" ;;
    g2)   script="g2-diff.sh"   ; gwd="$(task_wd)" ;;
    g2.5) script="g25-review.sh";;
    g3)   script="g3-human.sh"  ; gwd="$(task_wd)" ;;
    *)    die "unknown gate: $g (g0|g1|g2|g2.5|g3)";;
  esac
  mkdir -p "$td/report"
  rm -f "$td/report/$g.pass"
  local t0 ok=pass
  t0=$(date +%s)
  if [ "$g" = "g3" ]; then   # interactive: no log capture between human and diff
    "$HARNESS_HOME/gates/$script" "$td" "$gwd" || ok=fail
  else
    "$HARNESS_HOME/gates/$script" "$td" "$gwd" 2>&1 \
      | tee "$td/report/$g.log" || ok=fail
  fi
  printf '{"ts":"%s","phase":"gate:%s","result":"%s","duration_s":%d}\n' \
    "$(date +%Y-%m-%dT%H:%M:%S)" "$g" "$ok" "$(( $(date +%s) - t0 ))" \
    >> "$td/report/events.jsonl"
  [ "$ok" = "pass" ] || die "gate $g FAILED (log: .tasks/$name/report/$g.log)"
  touch "$td/report/$g.pass"
  info "gate $g PASSED"
}

case "$cmd" in
  init)
    root="$(repo_root "${1:-.}")"
    mkdir -p "$root/.tasks" "$root/decisions"
    [ -f "$root/AGENTS.md" ]     || cp "$HARNESS_HOME/templates/AGENTS.md" "$root/AGENTS.md"
    [ -e "$root/CLAUDE.md" ]     || ln -s AGENTS.md "$root/CLAUDE.md"   # one canonical file, no drift
    [ -f "$root/DIRECTION.md" ]  || cp "$HARNESS_HOME/templates/DIRECTION.md" "$root/DIRECTION.md"
    [ -f "$root/.harness.toml" ] || cp "$HARNESS_HOME/templates/harness.toml" "$root/.harness.toml"
    info "initialized $root (.tasks/, decisions/, AGENTS.md + CLAUDE.md symlink, DIRECTION.md, .harness.toml)"
    info "commit this scaffolding before starting tasks — untracked files fail G2's scope check"
    ;;
  spec)
    need_task "${1:-}"
    [ -f "$td/SPEC.md" ] && die "spec already exists: $td/SPEC.md"
    mkdir -p "$td/report"
    sed "s/{{TASK}}/$name/g" "$HARNESS_HOME/templates/SPEC.md" > "$td/SPEC.md"
    info "created $td/SPEC.md"
    info "next: write the spec, set 'Status: approved', then 'harness plan $name'"
    ;;
  critique)
    need_task "${1:-}"
    require_adapter
    [ -f "$td/SPEC.md" ] || die "no spec to critique — run 'harness spec $name' and write it first"
    # Preserve the prior critique so a re-critique can respect the human's edits
    # (the output redirect would otherwise truncate it before the agent reads it).
    [ -f "$td/report/spec-review.md" ] && mv "$td/report/spec-review.md" "$td/report/spec-review.prev.md"
    "$adapter" spec-critic "$td" "$root"
    echo
    render "$td/report/spec-review.md"
    echo
    info "advisory only — G0 still requires your own 'Status: approved' in SPEC.md"
    ;;
  split)
    need_task "${1:-}"
    require_adapter
    [ -f "$td/SPEC.md" ] || die "no spec to split — .tasks/$name/SPEC.md missing"
    "$adapter" spec-splitter "$td" "$root"
    out="$td/report/spec-split.md"
    [ -s "$out" ] || die "splitter produced no output"
    slugs=$(awk '/^=== SPEC: /{print $3}' "$out")
    [ -n "$slugs" ] || die "no '=== SPEC: <slug> ===' markers in splitter output — inspect $out"
    for s in $slugs; do
      case "$s" in
        *[!a-z0-9-]*|"") die "splitter produced an invalid slug: '$s'" ;;
      esac
      [ -d "$root/.tasks/$s" ] && die "task already exists: $s — refusing to overwrite"
    done
    for s in $slugs; do
      mkdir -p "$root/.tasks/$s/report"
      awk -v want="$s" '/^=== SPEC: /{cur=$3; next} cur==want' "$out" > "$root/.tasks/$s/SPEC.md"
      # Non-negotiable: staged splits are never pre-approved, whatever the agent wrote.
      python3 -c "import re,sys; p=sys.argv[1]; t=open(p).read(); open(p,'w').write(re.sub(r'(?im)^status:.*$','Status: draft',t))" "$root/.tasks/$s/SPEC.md"
      info "staged .tasks/$s/SPEC.md (Status: draft)"
    done
    info "reorganized, not authored — review and edit each split, approve each yourself,"
    info "then retire .tasks/$name (its SPEC.md is untouched)"
    ;;
  plan)
    need_task "${1:-}"
    require_adapter
    run_gate g0
    invalidate_from g1
    "$adapter" planner "$td" "$root"
    run_gate g1
    info "next: harness implement $name"
    ;;
  implement)
    need_task "${1:-}"
    require_adapter
    require_pass g0; require_pass g1
    invalidate_from g2
    wt="$(wt_path)"
    if [ ! -d "$wt" ]; then
      ensure_wt "$wt" "task/$name"
      info "worktree: $wt (branch task/$name) — your checkout stays untouched"
    fi
    bootstrap_wt "$wt"
    if [ "$(plan_tasks "$td/PLAN.md" | wc -l | tr -d ' ')" -gt 1 ]; then
      fan_out "$wt"
    else
      "$adapter" implementer "$td" "$wt"
    fi
    run_gate g2
    info "next: harness review $name"
    ;;
  review)
    need_task "${1:-}"
    require_adapter
    require_pass g2
    invalidate_from g2.5
    # Cross-model review: reviewer_model may be "model" or "adapter/model",
    # so the reviewer can run on a different CLI than the implementer.
    r_adapter="$adapter"
    rm_val=$(cfg "$root" reviewer_model "")
    case "$rm_val" in
      */*)
        r_adapter="$HARNESS_HOME/adapters/${rm_val%%/*}.sh"
        [ -x "$r_adapter" ] || die "no such adapter: ${rm_val%%/*} (reviewer_model=$rm_val)"
        export HARNESS_REVIEWER_MODEL="${rm_val#*/}"
        ;;
      ?*)
        # A bare value is a MODEL id. Catch the natural mistake of naming an
        # adapter here — it fails three steps later as "model not available".
        [ -x "$HARNESS_HOME/adapters/$rm_val.sh" ] && die "reviewer_model=\"$rm_val\" names an adapter, not a model. Use \"\" (current adapter, default model) or \"$rm_val/<model-id>\"."
        export HARNESS_REVIEWER_MODEL="$rm_val"
        ;;
    esac
    # The reviewer is read-only and diff-blind by permission; hand it the diff
    # as a file — evidence in files, not shell privileges.
    twd="$(task_wd)"
    {
      git -C "$twd" diff HEAD
      echo
      echo "# Untracked files (new; read their full content at these paths):"
      git -C "$twd" ls-files --others --exclude-standard | grep -vE '^(\.tasks/|decisions/)' || true
    } > "$td/report/diff.patch"
    "$r_adapter" reviewer "$td" "$twd"
    echo
    render "$td/report/review.md"    # shown before the gate: on a block, the review IS the news
    echo
    run_gate g2.5
    info "next: harness approve $name"
    ;;
  approve)
    need_task "${1:-}"
    require_pass g2.5
    run_gate g3
    info "next: harness merge $name"
    ;;
  merge)
    need_task "${1:-}"
    for g in $GATES; do require_pass "$g"; done   # merge means EVERY gate passed
    [ -f "$td/report/g3-approved" ] || die "no human approval record"
    twd="$(task_wd)"
    rec="$twd/decisions/$(date +%Y-%m-%d)-$name.md"
    mkdir -p "$twd/decisions"
    verdict=$(grep -iE '^VERDICT:' "$td/report/review.md" 2>/dev/null | tail -1 || echo "VERDICT: (no review)")
    read -r cost agent_s <<EOF2
$(python3 -c "
import json, sys
c = t = 0
for l in open(sys.argv[1]):
    if not l.strip(): continue
    d = json.loads(l)
    c += d.get('cost_usd') or 0
    t += d.get('duration_ms') or 0
print(round(c, 2), t // 1000)" "$td/report/events.jsonl" 2>/dev/null || echo "n/a n/a")
EOF2
    dstat=$(git -C "$twd" diff HEAD --stat 2>/dev/null | tail -1 | sed 's/^ *//')
    {
      echo "# Decision record — $name"
      echo
      echo "- Date: $(date +%Y-%m-%d)"
      echo "- Review: $verdict"
      echo "- Approved: $(cat "$td/report/g3-approved")"
      echo "- Gates: $(cd "$td/report" && for f in *.pass; do [ -e "$f" ] && printf '%s ' "${f%.pass}"; done)"
      echo "- Diff: ${dstat:-n/a}"
      echo "- Agent cost: \$$cost"
      echo "- Agent time: ${agent_s}s"
      echo
      echo "## Spec"
      echo
      sed -n '/^## Problem/,$p' "$td/SPEC.md"
    } > "$rec"
    if [ "$twd" != "$root" ]; then
      # The worktree must be ON task/$name — a detached or switched HEAD (e.g.
      # from a git-UI branch checkout) would make us merge the wrong ref and
      # lose the uncommitted work silently.
      cur=$(git -C "$twd" symbolic-ref -q --short HEAD || true)
      [ "$cur" = "task/$name" ] \
        || die "merge: worktree HEAD is '${cur:-detached}', not task/$name — your work is safe but unmergeable. Reattach: git -C $twd checkout task/$name"
      # Worktree flow: task metadata rides into history, commit on the task
      # branch, merge into the user's branch, clean up the sandbox.
      mkdir -p "$twd/.tasks"
      cp -R "$td" "$twd/.tasks/"
      git -C "$twd" add -A
      git -C "$twd" commit -q -m "task($name): merge via harness — gates G0–G3 passed"
      # The branch now carries .tasks/<name> (copied from root moments ago);
      # the root's untracked copy would block the merge — the merge restores it tracked.
      rm -rf "$td"
      git -C "$root" merge -q --no-ff "task/$name" -m "task($name): merge via harness — gates G0–G3 passed" \
        || die "merge conflict integrating task/$name — resolve in $root (worktree kept at $twd)"
      git -C "$root" worktree remove "$twd" >/dev/null 2>&1 || true
      git -C "$root" branch -q -d "task/$name" >/dev/null 2>&1 || true
    else
      git -C "$root" add -A
      git -C "$root" commit -q -m "task($name): merge via harness — gates G0–G3 passed"
    fi
    rec="$root/decisions/$(basename "$rec")"
    info "merged $(git -C "$root" rev-parse --short HEAD); decision record: decisions/$(basename "$rec")"
    # Vault writeback (build step 6): automatic when HARNESS_VAULT points at a
    # directory (your Obsidian vault); the in-repo decisions/ stays canonical.
    if [ -n "${HARNESS_VAULT:-}" ] && [ -d "$HARNESS_VAULT" ]; then
      rname="$(basename "$root")"
      vdir="$HARNESS_VAULT/harness/$rname"
      mkdir -p "$vdir"
      # Hub note per repo + previous-record link: records cluster and chain
      # in Obsidian's graph instead of floating unlinked.
      [ -f "$vdir/$rname.md" ] || printf -- '---\ntags: [harness, repo-hub]\n---\n\n# %s — harness decision records\n' "$rname" > "$vdir/$rname.md"
      prev=$(cd "$vdir" && for f in *.md; do
               [ "$f" = "$rname.md" ] && continue
               [ "$f" = "$(basename "$rec")" ] && continue
               echo "${f%.md}"
             done | sort | tail -1)
      {
        echo "---"
        echo "date: $(date +%Y-%m-%d)"
        echo "repo: $rname"
        echo "task: $name"
        echo "commit: $(git -C "$root" rev-parse --short HEAD)"
        echo "tags: [harness, decision-record]"
        echo "---"
        echo
        if [ -n "$prev" ]; then echo "[[$rname]] · previous: [[$prev]]"
        else echo "[[$rname]]"; fi
        echo
        cat "$rec"
      } > "$vdir/$(basename "$rec")"
      info "vault: $vdir/$(basename "$rec")"
    elif [ -n "${HARNESS_VAULT:-}" ]; then
      info "HARNESS_VAULT is set but not a directory — vault writeback skipped"
    fi
    ;;
  gate)
    g="${1:-}"; [ -n "$g" ] || die "usage: harness gate <g0|g1|g2|g2.5|g3> <task>"
    need_task "${2:-}"
    run_gate "$g"
    ;;
  diff)
    need_task "${1:-}"
    twd="$(task_wd)"
    [ "$twd" = "$root" ] || echo "task tree: $twd (branch task/$name)" >&2
    untracked=$(git -C "$twd" ls-files --others --exclude-standard | sed -e 's/^"//' -e 's/"$//' | grep -vE '^(\.tasks/|decisions/)' || true)
    emit_untracked() {
      [ -n "$untracked" ] || return 0
      echo; echo "── New (untracked) files ──"
      printf '%s\n' "$untracked" | sed 's/^/  + /'
    }
    if [ ! -t 1 ]; then                                   # piped/redirected: clean plain text
      git -C "$twd" diff HEAD 2>/dev/null; emit_untracked
    elif command -v delta >/dev/null 2>&1; then           # terminal + delta: syntax-highlighted, self-paging
      { git -C "$twd" diff HEAD 2>/dev/null; emit_untracked; } | delta
    else                                                  # terminal: colored, paged
      { git -C "$twd" -c color.ui=always diff HEAD 2>/dev/null; emit_untracked; } | ${PAGER:-less -R}
    fi
    ;;
  status)
    need_task "${1:-}"
    echo "task: $name"
    for g in $GATES; do
      if [ -f "$td/report/$g.pass" ]; then echo "  $g   ✓ pass"; else echo "  $g   · pending"; fi
    done
    [ -d "$(wt_path)" ] && echo "  worktree: $(wt_path) (branch task/$name)"
    ;;
  calibrate)
    python3 "$HARNESS_HOME/lib/calibrate.py" "$(repo_root .)"
    ;;
  stats)
    python3 "$HARNESS_HOME/lib/stats.py" "$(repo_root .)"
    ;;
  doctor)
    fails=0
    ck() {
      case "$1" in
        ok)   printf '  \342\234\223 %s%s\n' "$2" "${3:+ — $3}" ;;
        warn) printf '  ! %s%s\n' "$2" "${3:+ — $3}" ;;
        fail) printf '  \342\234\227 %s%s\n' "$2" "${3:+ — $3}"; fails=1 ;;
      esac
    }
    echo "harness doctor"
    if command -v python3 >/dev/null 2>&1; then ck ok "python3" "$(python3 -V 2>&1)"
    else ck fail "python3" "required by gates and adapters"; fi
    if command -v rg >/dev/null 2>&1; then ck ok "ripgrep"
    else ck warn "ripgrep" "G1 symbol checks fall back to slower grep"; fi
    if command -v glow >/dev/null 2>&1 || command -v bat >/dev/null 2>&1; then ck ok "markdown renderer"
    else ck warn "markdown renderer" "critiques/reviews print plain (brew install glow)"; fi
    if r=$(git rev-parse --show-toplevel 2>/dev/null); then
      ck ok "git repo" "$r"
      checks=$(discover_checks "$r" | awk '!seen[$0]++')
      if [ -n "$checks" ]; then ck ok "quality bar" "$(echo "$checks" | tr '\n' ';' | sed 's/;$//;s/;/; /g')"
      else ck fail "quality bar" "no lint/typecheck/test config — G2 will refuse (exit 2)"; fi
      if [ -f "$r/.harness.toml" ]; then ck ok ".harness.toml"
      else ck warn ".harness.toml" "using defaults (harness init writes one)"; fi
    else
      ck fail "git repo" "not inside one — the harness requires git"
    fi
    if [ -n "${HARNESS_VAULT:-}" ]; then
      if [ -d "$HARNESS_VAULT" ]; then ck ok "vault" "$HARNESS_VAULT"
      else ck warn "vault" "HARNESS_VAULT set but not a directory — writeback will skip"; fi
    fi
    a="${HARNESS_ADAPTER:-claude}"
    if [ -x "$HARNESS_HOME/adapters/$a.sh" ]; then ck ok "adapter" "$a"
    else ck fail "adapter" "$a — no adapters/$a.sh"; fi
    case "$a" in
      claude)
        if command -v claude >/dev/null 2>&1; then ck ok "claude CLI"
        else ck fail "claude CLI" "not on PATH"; fi ;;
      kiro)
        if command -v kiro-cli >/dev/null 2>&1 || command -v kiro >/dev/null 2>&1 || [ -x "${KIRO_BIN:-/nonexistent}" ]; then ck ok "kiro CLI"
        else ck fail "kiro CLI" "not on PATH (set KIRO_BIN to override)"; fi ;;
    esac
    exit "$fails"
    ;;
  version)
    v=$(cat "$HARNESS_HOME/VERSION" 2>/dev/null || echo dev)
    sha=$(git -C "$HARNESS_HOME" rev-parse --short HEAD 2>/dev/null || echo unreleased)
    echo "harness $v ($sha)"
    ;;
  loc)
    root="$(repo_root .)"
    p=0; t=0; d=0
    while IFS= read -r f; do
      [ -f "$root/$f" ] || continue
      [ -n "$(lockfile_manifest "$f")" ] && continue
      case "$f" in *.png|*.jpg|*.jpeg|*.gif|*.ico|*.pdf|*.woff|*.woff2|*.lockb) continue ;; esac
      n=$(wc -l < "$root/$f")
      case "$f" in
        *.md) d=$((d + n)) ;;
        *) if is_test_file "$f"; then t=$((t + n)); else p=$((p + n)); fi ;;
      esac
    done <<EOF
$(git -C "$root" ls-files)
EOF
    hn() { local h; h="$(fmt_n "$1")"; if [ "$h" = "$1" ]; then echo "$1"; else echo "$h ($1)"; fi; }
    echo "repo:    $root (tracked files; lockfiles excluded)"
    echo "product: $(hn "$p")"
    echo "tests:   $(hn "$t")"
    echo "docs:    $(hn "$d") — *.md"
    echo "total:   $(hn "$((p + t + d))")"
    read -r ap at ad <<EOF2
$(diff_adds "$root")
EOF2
    if [ "$((ap + at + ad))" -gt 0 ]; then
      echo "uncommitted: +$(fmt_n "$ap") product, +$(fmt_n "$at") tests, -$(fmt_n "$ad") deleted — what G2's budget will see"
    fi
    if [ "$root" = "$HARNESS_HOME" ]; then
      b=$(cat "$HARNESS_HOME"/bin/harness "$HARNESS_HOME"/lib/*.sh "$HARNESS_HOME"/lib/*.py \
              "$HARNESS_HOME"/gates/*.sh "$HARNESS_HOME"/adapters/*.sh | wc -l | tr -d ' ')
    echo "budget:  $b of ~1500 (bin+lib+gates+adapters — HARNESS-PLAN.md §9)"
    fi
    ;;
  help|-h|--help) usage ;;
  *) echo "harness: unknown command '$cmd'" >&2; usage 1 ;;
esac
